{
  "name": "@kibologic/swite",
  "version": "0.2.30",
  "description": "SWITE - SWISS Development Server (Vite replacement)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "swite": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "rm -rf dist node_modules && rm -f tsconfig.tsbuildinfo",
    "generate-import-map": "tsx src/utils/generate-import-map-cli.ts",
    "test": "node --import tsx --test __tests__/import-rewriter-bug.test.ts",
    "changeset": "changeset",
    "release:version": "changeset version",
    "release:publish": "changeset publish"
  },
  "dependencies": {
    "@kibologic/core": "link:../swiss-lib/packages/core",
    "@kibologic/compiler": "link:../swiss-lib/packages/compiler",
    "@kibologic/plugin-file-router": "link:../swiss-lib/packages/plugins/file-router",
    "chalk": "^5.3.0",
    "chokidar": "^3.5.3",
    "es-module-lexer": "^1.3.1",
    "esbuild": "^0.25.0",
    "express": "^4.18.2",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "18.19.121",
    "@types/ws": "^8.5.8",
    "@changesets/cli": "^2.29.5",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kibologic/alpine-erp-core.git"
  }
}
